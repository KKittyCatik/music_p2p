{
  "annotations": {
    "list": []
  },
  "description": "Music P2P Node Observability Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "Connected Peers",
      "type": "gauge",
      "targets": [
        { "datasource": "Prometheus", "expr": "music_p2p_peers_connected", "legendFormat": "{{instance}}", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 4, "y": 0 },
      "id": 2,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Chunks Downloaded / Failed Rate",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(music_p2p_chunks_downloaded_total[1m])", "legendFormat": "Downloaded/s {{instance}}", "refId": "A" },
        { "datasource": "Prometheus", "expr": "rate(music_p2p_chunks_failed_total[1m])", "legendFormat": "Failed/s {{instance}}", "refId": "B" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 10 }] } }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "id": 3,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Buffer Level (chunks)",
      "type": "gauge",
      "targets": [
        { "datasource": "Prometheus", "expr": "music_p2p_buffer_level_chunks", "legendFormat": "{{instance}}", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Bandwidth (bytes/s)",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "music_p2p_bandwidth_bps", "legendFormat": "Bandwidth {{instance}}", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "HTTP Request Rate by Endpoint",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(music_p2p_http_requests_total[1m])", "legendFormat": "{{method}} {{path}} {{status}}", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "HTTP Latency by Endpoint (p99)",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, rate(music_p2p_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99 {{method}} {{path}}", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Active / Idle Pool Streams",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "music_p2p_pool_active_streams", "legendFormat": "Active {{instance}}", "refId": "A" },
        { "datasource": "Prometheus", "expr": "music_p2p_pool_idle_streams", "legendFormat": "Idle {{instance}}", "refId": "B" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 24 },
      "id": 8,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Stall Events",
      "type": "stat",
      "targets": [
        { "datasource": "Prometheus", "expr": "music_p2p_stall_events_total", "legendFormat": "Stalls {{instance}}", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 24 },
      "id": 9,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Tracks Played",
      "type": "stat",
      "targets": [
        { "datasource": "Prometheus", "expr": "music_p2p_tracks_played_total", "legendFormat": "Played {{instance}}", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 24 },
      "id": 10,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Seek Events",
      "type": "stat",
      "targets": [
        { "datasource": "Prometheus", "expr": "music_p2p_seek_events_total", "legendFormat": "Seeks {{instance}}", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["music_p2p"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Music P2P Dashboard",
  "uid": "music_p2p_main",
  "version": 1
}
